<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Join Team on KeyConnect+</title>
  <meta name="description" content="You've been invited to join a team on KeyConnect+" />

  <!-- Prevent search engines indexing invite links -->
  <meta name="robots" content="noindex, nofollow" />

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      color: #fff;
    }

    .card {
      background: rgba(255,255,255,0.07);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 28px;
      padding: 40px 32px;
      max-width: 400px;
      width: 100%;
      text-align: center;
      box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    }

    .logo {
      width: 80px;
      height: 80px;
      border-radius: 22px;
      margin: 0 auto 20px;
      display: block;
      background: rgba(255,255,255,0.1);
      object-fit: cover;
    }

    .app-name {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.5);
      margin-bottom: 8px;
    }

    .headline {
      font-size: 26px;
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 8px;
      color: #fff;
    }

    .team-name {
      color: #60a5fa;
    }

    .subtext {
      font-size: 14px;
      color: rgba(255,255,255,0.55);
      margin-bottom: 32px;
      line-height: 1.5;
    }

    /* Spinner shown while trying to open the app */
    .spinner-wrap {
      margin: 0 auto 28px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
    }

    .spinner {
      width: 40px;
      height: 40px;
      border: 3px solid rgba(255,255,255,0.15);
      border-top-color: #60a5fa;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .spinner-label {
      font-size: 13px;
      color: rgba(255,255,255,0.5);
    }

    /* Store buttons shown after timeout */
    .store-buttons { display: none; flex-direction: column; gap: 14px; }
    .store-buttons.visible { display: flex; }

    .btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 16px 24px;
      border-radius: 16px;
      font-size: 15px;
      font-weight: 600;
      text-decoration: none;
      transition: transform 0.15s, opacity 0.15s;
      cursor: pointer;
      border: none;
    }

    .btn:active { transform: scale(0.97); opacity: 0.85; }

    .btn-appstore {
      background: #fff;
      color: #000;
    }

    .btn-playstore {
      background: #34a853;
      color: #fff;
    }

    .btn svg { flex-shrink: 0; }

    .divider {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 4px 0;
      color: rgba(255,255,255,0.25);
      font-size: 12px;
    }
    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(255,255,255,0.1);
    }

    .already-installed {
      margin-top: 24px;
      font-size: 12px;
      color: rgba(255,255,255,0.35);
    }

    .already-installed a {
      color: #60a5fa;
      text-decoration: none;
    }

    .badge {
      display: inline-block;
      background: rgba(96,165,250,0.15);
      border: 1px solid rgba(96,165,250,0.3);
      color: #60a5fa;
      font-size: 12px;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 20px;
      letter-spacing: 0.5px;
    }
  </style>
</head>
<body>
<div class="card">
  <img src="https://keychainapplications.github.io/keyconnect-home/icon-512x512.png"
       alt="KeyConnect+" class="logo" />

  <div class="app-name">KeyConnect+</div>

  <div id="badge" class="badge">Team Invite</div>

  <h1 class="headline" id="headline">
    You're invited to join<br>
    <span class="team-name" id="teamNameEl">a team</span>
  </h1>

  <p class="subtext" id="subtext">
    Opening KeyConnect+ for you…
  </p>

  <!-- Spinner while trying to open the app -->
  <div class="spinner-wrap" id="spinnerWrap">
    <div class="spinner"></div>
    <div class="spinner-label">Redirecting to app…</div>
  </div>

  <!-- Store buttons shown if app is not installed -->
  <div class="store-buttons" id="storeButtons">
    <a href="#" id="appStoreBtn" class="btn btn-appstore">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
      </svg>
      Download on the App Store
    </a>

    <div class="divider">or</div>

    <a href="#" id="playStoreBtn" class="btn btn-playstore">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M3.18 23.76c.3.17.64.22.99.14l12.12-6.99-2.54-2.54-10.57 9.39zm-1.5-20.3C1.45 3.83 1.33 4.26 1.33 4.8v14.4c0 .54.12.97.35 1.34l.07.07 8.07-8.07v-.19L1.75 4.28l-.07.18zm17.28 9.6l-2.3-1.33-2.85 2.85 2.85 2.84 2.32-1.34c.66-.38.66-1.23-.02-1.62v.6zm-15.78 8.7l10.54-9.38-2.54-2.54L1.68 20.18l1.5 1.58z"/>
      </svg>
      Get it on Google Play
    </a>
  </div>

  <p class="already-installed" id="alreadyInstalled" style="display:none">
    Already have the app?
    <a href="#" id="openAppLink">Open KeyConnect+</a>
  </p>
</div>

<script>
  const APP_STORE_URL  = 'https://apps.apple.com/app/keyconnect/id6776106885';
  const PLAY_STORE_URL = 'https://play.google.com/store/apps/details?id=com.keyconnect.keychainapps';
  const CLIPBOARD_PREFIX = 'keyconnect-join:';

  // ── Parse query params ───────────────────────────────────────────────────────
  const params  = new URLSearchParams(window.location.search);
  const type    = params.get('type') || 'team';
  const team    = params.get('team') || '';
  const ref     = params.get('ref')  || '';
  const name    = params.get('name') || '';
  const code    = params.get('code') || ''; // referral type

  // ── Update UI ────────────────────────────────────────────────────────────────
  const teamNameEl = document.getElementById('teamNameEl');
  const headline   = document.getElementById('headline');
  const subtext    = document.getElementById('subtext');
  const badge      = document.getElementById('badge');

  if (type === 'ref') {
    badge.textContent      = 'Referral Invite';
    headline.innerHTML     = 'Join <span class="team-name">KeyConnect+</span>';
    subtext.textContent    = 'Someone invited you to join KeyConnect+. Download the app to get started!';
  } else {
    const displayName = name ? decodeURIComponent(name) : 'a team';
    teamNameEl.textContent = displayName;
  }

  // ── Build deep link URL ───────────────────────────────────────────────────────
  function buildDeepLink(scheme) {
    if (type === 'ref') {
      return `${scheme}://join?type=ref&code=${encodeURIComponent(code)}`;
    }
    let url = `${scheme}://join?type=team&team=${encodeURIComponent(team)}`;
    if (ref)  url += `&ref=${encodeURIComponent(ref)}`;
    if (name) url += `&name=${encodeURIComponent(name)}`;
    return url;
  }

  const appDeepLink = buildDeepLink('keyconnect');
  const webUrl      = window.location.href; // full current URL

  // ── Copy deferred deep link to clipboard ─────────────────────────────────────
  // When the app isn't installed, the user installs it and on first launch
  // the app reads the clipboard to recover the join intent.
  function copyDeferredLink() {
    try {
      navigator.clipboard.writeText(CLIPBOARD_PREFIX + webUrl).catch(() => {
        // Fallback for browsers that block clipboard without interaction
        const el = document.createElement('textarea');
        el.value = CLIPBOARD_PREFIX + webUrl;
        el.style.position = 'fixed';
        el.style.opacity  = '0';
        document.body.appendChild(el);
        el.focus();
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
      });
    } catch (_) {}
  }

  // ── Store button links ────────────────────────────────────────────────────────
  const isIOS     = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isAndroid = /android/i.test(navigator.userAgent);

  document.getElementById('appStoreBtn').href  = APP_STORE_URL;
  document.getElementById('playStoreBtn').href = PLAY_STORE_URL;
  document.getElementById('openAppLink').href  = appDeepLink;

  // On iOS hide Play Store; on Android hide App Store
  if (isIOS) {
    document.getElementById('playStoreBtn').parentElement.style.display = 'none';
    document.getElementById('playStoreBtn').style.display = 'none';
    const divider = document.querySelector('.divider');
    if (divider) divider.style.display = 'none';
  } else if (isAndroid) {
    document.getElementById('appStoreBtn').style.display = 'none';
    const divider = document.querySelector('.divider');
    if (divider) divider.style.display = 'none';
  }

  // ── Try to open the app ───────────────────────────────────────────────────────
  function showStoreFallback() {
    document.getElementById('spinnerWrap').style.display     = 'none';
    document.getElementById('storeButtons').classList.add('visible');
    document.getElementById('alreadyInstalled').style.display = 'block';
    subtext.textContent = 'Get KeyConnect+ to join your team instantly.';
    copyDeferredLink();
  }

  // Try the custom scheme. If the app opens, the page goes to background and the
  // timeout never fires visibly. If the app is not installed the page stays and
  // we show the store buttons after the delay.
  let appOpened = false;

  function tryOpenApp() {
    const iframe = document.createElement('iframe');
    iframe.style.display = 'none';
    iframe.src = appDeepLink;
    document.body.appendChild(iframe);

    // Also try via window.location as fallback for some browsers
    setTimeout(() => {
      try { window.location = appDeepLink; } catch(_) {}
    }, 100);

    // After 2.2s, if we're still here, the app is not installed
    setTimeout(() => {
      if (!document.hidden) {
        showStoreFallback();
      }
    }, 2200);
  }

  // Handle visibility change — if app opened and user comes back, keep store shown
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) {
      // User came back from app or app wasn't installed
    }
  });

  // Small delay to let the page render before attempting redirect
  setTimeout(tryOpenApp, 300);
</script>
</body>
</html>
